# OpenRouter (https://openrouter.ai) - GitHub 업로드 금지
OPENROUTER_API_KEY=

# App URL (Vision API 이미지 접근용)
NEXT_PUBLIC_APP_URL=http://localhost:50004

# Vercel 배포 시 필수 - Upstash Redis (Storage → Upstash Redis 연동)
# Vercel 연동 시 KV_REST_API_* 로 자동 주입될 수 있음
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI Hub (https://aihub.or.kr) - GitHub 업로드 금지
AIHUB_API_KEY=
AIHUB_SHELL_PATH=
AIHUB_DOWNLOAD_DIR=

# Server (로컬 개발용, Vercel에서는 자동)
PORT=50004
